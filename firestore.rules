rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: products
    // Fields: name (string), sku (string), category (string), price (number), cost (number), stock (number), stockLeft (number), stockRight (number), unit (string)
    //
    // Collection: suppliers
    // Fields: name (string), contact (string), email (string), phone (string)
    //
    // Collection: customers
    // Fields: name (string), email (string), phone (string)
    //
    // Collection: purchases
    // Fields: supplierId (string), date (string), items (list of maps), total (number)
    //
    // Collection: sales
    // Fields: customerId (string), date (string), items (list of maps), total (number)
    //
    // Collection: transactions
    // Fields: date (string), description (string), type (string: income|expense), amount (number), category (string)
    //
    // Collection: transfers
    // Fields: fromWarehouseId (string), toWarehouseId (string), productId (string), quantityLeft (number), quantityRight (number), date (string)
    //
    // Collection: returns
    // Fields: saleId (string), date (string), items (list of maps), totalRefund (number), status (string)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "yahia1671999@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProduct(data) {
      return hasRequiredFields(['name', 'sku', 'price', 'cost', 'stock', 'stockLeft', 'stockRight']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.sku is string && data.sku.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.cost is number && data.cost >= 0 &&
             data.stock is number &&
             data.stockLeft is number &&
             data.stockRight is number &&
             (!('piecesPerCarton' in data) || (data.piecesPerCarton is number && data.piecesPerCarton >= 0)) &&
             (!('cartonPrice' in data) || (data.cartonPrice is number && data.cartonPrice >= 0)) &&
             (!('cartonCost' in data) || (data.cartonCost is number && data.cartonCost >= 0));
    }

    function isValidSupplier(data) {
      return hasRequiredFields(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidCustomer(data) {
      return hasRequiredFields(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidPurchase(data) {
      return hasRequiredFields(['supplierId', 'date', 'items', 'total']) &&
             data.supplierId is string &&
             data.items is list &&
             data.total is number && data.total >= 0 &&
             (!('invoiceUrl' in data) || data.invoiceUrl is string);
    }

    function isValidSale(data) {
      return hasRequiredFields(['customerId', 'date', 'items', 'total']) &&
             data.customerId is string &&
             data.items is list &&
             data.total is number && data.total >= 0 &&
             (!('discount' in data) || (data.discount is number && data.discount >= 0));
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['date', 'description', 'type', 'amount']) &&
             data.description is string &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount >= 0;
    }

    function isValidTransfer(data) {
      return hasRequiredFields(['fromWarehouseId', 'toWarehouseId', 'productId', 'quantityLeft', 'quantityRight', 'date']) &&
             data.fromWarehouseId is string &&
             data.toWarehouseId is string &&
             data.productId is string &&
             data.quantityLeft is number &&
             data.quantityRight is number &&
             data.date is string;
    }

    function isValidReturn(data) {
      return hasRequiredFields(['saleId', 'date', 'items', 'totalRefund', 'status']) &&
             data.saleId is string &&
             data.date is string &&
             data.items is list &&
             data.totalRefund is number &&
             data.status in ['completed', 'pending'];
    }

    function hasPermission(screenId, action) {
      return isAuthenticated();
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    function isValidUser(data) {
      return hasRequiredFields(['email', 'role', 'isActive']) &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.isActive is bool;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && (
          // Default for new users
          (request.resource.data.role == 'user' && request.resource.data.isActive == false) ||
          // Allow migration if email-based doc exists and matches
          (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && 
           get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == request.resource.data.role &&
           get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.isActive == request.resource.data.isActive)
        ))
      );
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.isActive == resource.data.isActive &&
         request.resource.data.email == resource.data.email)
      );
      allow delete: if isAdmin() || (isAuthenticated() && (request.auth.uid == userId || request.auth.token.email == userId));
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('inventory', 'canAdd') && isValidProduct(request.resource.data);
      allow update: if hasPermission('inventory', 'canEdit') && isValidProduct(request.resource.data);
      allow delete: if hasPermission('inventory', 'canDelete');
    }

    match /warehouses/{warehouseId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('warehouses', 'canAdd') && hasRequiredFields(['name']);
      allow update: if hasPermission('warehouses', 'canEdit') && hasRequiredFields(['name']);
      allow delete: if hasPermission('warehouses', 'canDelete');
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('suppliers', 'canAdd') && isValidSupplier(request.resource.data);
      allow update: if hasPermission('suppliers', 'canEdit') && isValidSupplier(request.resource.data);
      allow delete: if hasPermission('suppliers', 'canDelete');
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('customers', 'canAdd') && isValidCustomer(request.resource.data);
      allow update: if hasPermission('customers', 'canEdit') && isValidCustomer(request.resource.data);
      allow delete: if hasPermission('customers', 'canDelete');
    }

    match /purchases/{purchaseId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('purchases', 'canAdd') && isValidPurchase(request.resource.data);
      allow update: if hasPermission('purchases', 'canEdit');
      allow delete: if hasPermission('purchases', 'canDelete');
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('sales', 'canAdd') && isValidSale(request.resource.data);
      allow update: if hasPermission('sales', 'canEdit');
      allow delete: if hasPermission('sales', 'canDelete');
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('accounting', 'canAdd') && isValidTransaction(request.resource.data);
      allow update: if hasPermission('accounting', 'canEdit');
      allow delete: if hasPermission('accounting', 'canDelete');
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('categories', 'canAdd') && hasRequiredFields(['name']);
      allow update: if hasPermission('categories', 'canEdit') && hasRequiredFields(['name']);
      allow delete: if hasPermission('categories', 'canDelete');
    }

    match /transfers/{transferId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('transfers', 'canAdd') && isValidTransfer(request.resource.data);
      allow update: if hasPermission('transfers', 'canEdit');
      allow delete: if hasPermission('transfers', 'canDelete');
    }

    match /returns/{returnId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('returns', 'canAdd') && isValidReturn(request.resource.data);
      allow update: if hasPermission('returns', 'canEdit');
      allow delete: if hasPermission('returns', 'canDelete');
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
